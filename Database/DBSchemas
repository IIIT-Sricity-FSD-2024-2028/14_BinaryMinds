 CREATE DATABASE IF NOT EXISTS licensing_system;
USE licensing_system;


CREATE TABLE users (
/*
| Entity        | Description                                         |
|---------------|-----------------------------------------------------|
| user_id       | PK - Unique user identifier                         |
| full_name     | User full name                                      |
| email         | Unique login email                                  |
| phone         | Unique contact number                               |
| password_hash | Bcrypt hashed password                              |
| role          | RBAC role: applicant / field_officer /              |
|               | department_officer                                  |
| created_at    | Account creation timestamp                          |
*/
    user_id        INT          AUTO_INCREMENT PRIMARY KEY,
    full_name      VARCHAR(120) NOT NULL,
    email          VARCHAR(120) UNIQUE NOT NULL,
    phone          VARCHAR(15)  UNIQUE NOT NULL,
    password_hash  VARCHAR(255) NOT NULL,
    role           ENUM('applicant','field_officer','department_officer') NOT NULL,
    created_at     TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);


CREATE TABLE applications (
/*
| Entity              | Description                                     |
|---------------------|-------------------------------------------------|
| application_id      | PK - Unique application identifier              |
| applicant_id        | FK - users(user_id) - Who submitted             |
| full_name           | Applicant full name on form                     |
| father_name         | Father name                                     |
| date_of_birth       | Date of birth                                   |
| gender              | Gender                                          |
| aadhaar_number      | Unique Aadhaar number                           |
| applicant_phone     | Contact phone on application                    |
| business_name       | Registered business name                        |
| business_type       | Type of business                                |
| trade_category      | Trade license category                          |
| shop_address        | Full shop / business address                    |
| city                | City                                            |
| district            | District                                        |
| state               | State                                           |
| pincode             | Postal code                                     |
| business_start_date | Date business started                           |
| application_status  | submitted / documents_uploaded /                |
|                     | inspection_scheduled / inspection_completed /   |
|                     | department_review / approved / rejected         |
| submitted_at        | Submission timestamp                            |
*/
    application_id       INT          AUTO_INCREMENT PRIMARY KEY,
    applicant_id         INT          NOT NULL,
    full_name            VARCHAR(120) NOT NULL,
    father_name          VARCHAR(120),
    date_of_birth        DATE,
    gender               VARCHAR(20),
    aadhaar_number       VARCHAR(20)  UNIQUE,
    applicant_phone      VARCHAR(15),
    business_name        VARCHAR(150) NOT NULL,
    business_type        VARCHAR(100),
    trade_category       VARCHAR(100),
    shop_address         TEXT,
    city                 VARCHAR(100),
    district             VARCHAR(100),
    state                VARCHAR(100),
    pincode              VARCHAR(10),
    business_start_date  DATE,
    application_status   ENUM(
                             'submitted',
                             'documents_uploaded',
                             'inspection_scheduled',
                             'inspection_completed',
                             'department_review',
                             'approved',
                             'rejected'
                         ) DEFAULT 'submitted',
    submitted_at         TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (applicant_id) REFERENCES users(user_id)
);


CREATE TABLE documents (
/*
| Entity              | Description                                     |
|---------------------|-------------------------------------------------|
| document_id         | PK - Unique document identifier                 |
| application_id      | FK - applications(application_id)               |
| document_type       | aadhar_card / business_affidavit /              |
|                     | passport_photo                                  |
| file_path           | Server path to stored file                      |
| verification_status | pending / verified / rejected                   |
| uploaded_at         | Upload timestamp                                |
*/
    document_id          INT          AUTO_INCREMENT PRIMARY KEY,
    application_id       INT          NOT NULL,
    document_type        ENUM('aadhar_card','business_affidavit','passport_photo') NOT NULL,
    file_path            VARCHAR(255) NOT NULL,
    verification_status  ENUM('pending','verified','rejected') DEFAULT 'pending',
    uploaded_at          TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (application_id) REFERENCES applications(application_id)
);


CREATE TABLE payments (
/*
| Entity                | Description                                   |
|-----------------------|-----------------------------------------------|
| payment_id            | PK - Unique payment identifier                |
| application_id        | FK - applications(application_id)             |
| amount                | Fee amount paid                               |
| transaction_reference | Payment gateway reference number              |
| payment_status        | pending / success / failed                    |
| payment_date          | Payment timestamp                             |
*/
    payment_id             INT           AUTO_INCREMENT PRIMARY KEY,
    application_id         INT           NOT NULL,
    amount                 DECIMAL(10,2) NOT NULL,
    transaction_reference  VARCHAR(100),
    payment_status         ENUM('pending','success','failed') DEFAULT 'pending',
    payment_date           TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (application_id) REFERENCES applications(application_id)
);


CREATE TABLE document_verifications (
/*
| Entity              | Description                                     |
|---------------------|-------------------------------------------------|
| verification_id     | PK - Unique verification record                 |
| application_id      | FK - applications(application_id)               |
| field_officer_id    | FK - users(user_id) - Officer who verified      |
| verification_status | pending / approved_for_inspection /             |
|                     | rejected_on_verification                        |
| rejection_reason    | Reason if rejected - stored in history          |
| verified_at         | Verification timestamp                          |
*/
    verification_id      INT  AUTO_INCREMENT PRIMARY KEY,
    application_id       INT  NOT NULL,
    field_officer_id     INT  NOT NULL,
    verification_status  ENUM(
                             'pending',
                             'approved_for_inspection',
                             'rejected_on_verification'
                         ) DEFAULT 'pending',
    rejection_reason     TEXT,
    verified_at          TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (application_id)   REFERENCES applications(application_id),
    FOREIGN KEY (field_officer_id) REFERENCES users(user_id)
);


CREATE TABLE field_officer_assignments (
/*
| Entity                  | Description                                 |
|-------------------------|---------------------------------------------|
| assignment_id           | PK - Unique assignment identifier           |
| application_id          | FK - applications(application_id)           |
| field_officer_id        | FK - users(user_id) - Assigned officer      |
| assigned_at             | Assignment timestamp                        |
| inspection_date         | Scheduled inspection date                   |
| sla_deadline            | 7-day SLA deadline from assignment date     |
| assignment_status       | assigned / inspection_scheduled /           |
|                         | inspection_completed / sla_escalated        |
| escalated_to_department | TRUE if SLA breached and escalated          |
*/
    assignment_id            INT      AUTO_INCREMENT PRIMARY KEY,
    application_id           INT      NOT NULL,
    field_officer_id         INT      NOT NULL,
    assigned_at              TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    inspection_date          DATE,
    sla_deadline             DATE,
    assignment_status        ENUM(
                                 'assigned',
                                 'inspection_scheduled',
                                 'inspection_completed',
                                 'sla_escalated'
                             ) DEFAULT 'assigned',
    escalated_to_department  BOOLEAN DEFAULT FALSE,

    FOREIGN KEY (application_id)   REFERENCES applications(application_id),
    FOREIGN KEY (field_officer_id) REFERENCES users(user_id)
);


CREATE TABLE inspections (
/*
| Entity            | Description                                       |
|-------------------|---------------------------------------------------|
| inspection_id     | PK - Unique inspection identifier                 |
| application_id    | FK - applications(application_id)                 |
| field_officer_id  | FK - users(user_id) - Officer who inspected       |
| inspection_date   | Date inspection was conducted                     |
| inspection_report | Detailed observations written by officer          |
| inspection_result | approved / rejected                               |
| submitted_at      | Report submission timestamp                       |
*/
    inspection_id     INT  AUTO_INCREMENT PRIMARY KEY,
    application_id    INT  NOT NULL,
    field_officer_id  INT  NOT NULL,
    inspection_date   DATE,
    inspection_report TEXT,
    inspection_result ENUM('approved','rejected'),
    submitted_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (application_id)   REFERENCES applications(application_id),
    FOREIGN KEY (field_officer_id) REFERENCES users(user_id)
);


CREATE TABLE department_reviews (
/*
| Entity                | Description                                   |
|-----------------------|-----------------------------------------------|
| review_id             | PK - Unique review identifier                 |
| application_id        | FK - applications(application_id)             |
| department_officer_id | FK - users(user_id) - Officer who reviewed    |
| review_type           | normal_review / sla_escalation                |
| review_status         | approved / rejected                           |
| review_comments       | Mandatory justification / decision comments   |
| digital_signature     | Officer digital signature string              |
| reviewed_at           | Review timestamp                              |
*/
    review_id              INT  AUTO_INCREMENT PRIMARY KEY,
    application_id         INT  NOT NULL,
    department_officer_id  INT  NOT NULL,
    review_type            ENUM('normal_review','sla_escalation') DEFAULT 'normal_review',
    review_status          ENUM('approved','rejected'),
    review_comments        TEXT,
    digital_signature      VARCHAR(255),
    reviewed_at            TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (application_id)        REFERENCES applications(application_id),
    FOREIGN KEY (department_officer_id) REFERENCES users(user_id)
);


CREATE TABLE licenses (
/*
| Entity         | Description                                      |
|----------------|--------------------------------------------------|
| license_id     | PK - Unique license identifier                   |
| application_id | FK - applications(application_id)                |
| license_number | Unique license certificate number                |
| issue_date     | Date license was issued                          |
| expiry_date    | License validity end date                        |
| license_status | active / renewal_required / expired /            |
|                | suspended / cancelled                            |
*/
    license_id      INT         AUTO_INCREMENT PRIMARY KEY,
    application_id  INT         NOT NULL,
    license_number  VARCHAR(50) UNIQUE,
    issue_date      DATE,
    expiry_date     DATE,
    license_status  ENUM(
                        'active',
                        'renewal_required',
                        'expired',
                        'suspended',
                        'cancelled'
                    ) DEFAULT 'active',

    FOREIGN KEY (application_id) REFERENCES applications(application_id)
);


CREATE TABLE license_renewals (
/*
| Entity          | Description                                     |
|-----------------|-------------------------------------------------|
| renewal_id      | PK - Unique renewal identifier                  |
| license_id      | FK - licenses(license_id)                       |
| renewal_fee     | Fee paid for renewal                            |
| renewal_status  | submitted / inspection_scheduled /              |
|                 | inspection_completed / department_review /      |
|                 | approved / rejected                             |
| new_expiry_date | Updated expiry date after renewal approval      |
| submitted_at    | Renewal request timestamp                       |
*/
    renewal_id       INT           AUTO_INCREMENT PRIMARY KEY,
    license_id       INT           NOT NULL,
    renewal_fee      DECIMAL(10,2),
    renewal_status   ENUM(
                         'submitted',
                         'inspection_scheduled',
                         'inspection_completed',
                         'department_review',
                         'approved',
                         'rejected'
                     ) DEFAULT 'submitted',
    new_expiry_date  DATE,
    submitted_at     TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (license_id) REFERENCES licenses(license_id)
);


CREATE TABLE compliance_violations (
/*
| Entity                | Description                                   |
|-----------------------|-----------------------------------------------|
| violation_id          | PK - Unique violation identifier              |
| license_id            | FK - licenses(license_id)                     |
| reported_by           | FK - users(user_id) - Officer who reported    |
| violation_type        | Category of violation                         |
| violation_description | Detailed description of violation             |
| action_taken          | warning / fine / suspended /                  |
|                       | license_cancelled                             |
| reported_at           | Violation report timestamp                    |
*/
    violation_id           INT  AUTO_INCREMENT PRIMARY KEY,
    license_id             INT  NOT NULL,
    reported_by            INT  NOT NULL,
    violation_type         VARCHAR(150),
    violation_description  TEXT,
    action_taken           ENUM('warning','fine','suspended','license_cancelled'),
    reported_at            TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (license_id)  REFERENCES licenses(license_id),
    FOREIGN KEY (reported_by) REFERENCES users(user_id)
);


CREATE TABLE field_officer_warnings (
/*
| Entity           | Description                                    |
|------------------|------------------------------------------------|
| warning_id       | PK - Unique warning identifier                 |
| field_officer_id | FK - users(user_id) - Officer who was warned   |
| application_id   | FK - applications(application_id)              |
| warning_reason   | Reason for warning - SLA breach description    |
| warning_date     | Warning issued timestamp                       |
*/
    warning_id        INT  AUTO_INCREMENT PRIMARY KEY,
    field_officer_id  INT  NOT NULL,
    application_id    INT  NOT NULL,
    warning_reason    VARCHAR(255),
    warning_date      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (field_officer_id) REFERENCES users(user_id),
    FOREIGN KEY (application_id)   REFERENCES applications(application_id)
);
